{
  "name": "@satyam1990/learn-mcp",
  "version": "1.0.1",
  "main": "src/server.ts",
  "type": "module",
  "bin": {
    "my-mcp-server": "bin/cli.js"
  },
  "scripts": {
    "serve:build": "tsc",
    "server:build:watch": "tsc --watch",
    "server:dev": "tsx src/server.ts",
    "server:inspect": "set DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector npm run server:dev",
    "client:dev": "tsx src/client.ts",
    "prepublishOnly": "npm run serve:build"
  },
  "keywords": [
    "mcp",
    "server",
    "learn",
    "mcp-server",
    "mcp-client"
  ],
  "files": [
    "build",
    "README.md"
  ],
  "author": "Satyam",
  "license": "MIT",
  "description": "A simple MCP server that learns from the user with Google AI SDK",
  "dependencies": {
    "@ai-sdk/google": "^3.0.34",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ai": "^6.0.105",
    "dotenv": "^17.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.15.0",
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
